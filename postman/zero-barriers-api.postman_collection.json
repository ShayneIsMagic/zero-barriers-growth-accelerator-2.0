{
  "info": {
    "name": "Zero Barriers Growth Accelerator API",
    "description": "Synced with API_DOCUMENTATION.md. Set {{baseUrl}} and {{authToken}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "authToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign in",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"you@example.com\",\n  \"password\": \"your-password\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/signin"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "Sign out",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/signout"
          }
        }
      ]
    },
    {
      "name": "System",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health"
          }
        },
        {
          "name": "System status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/api/system/status"
          }
        }
      ]
    },
    {
      "name": "Content",
      "item": [
        {
          "name": "Collect (unified)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com\",\n  \"mode\": \"comprehensive\"\n}"
            },
            "url": "{{baseUrl}}/api/content/collect"
          }
        },
        {
          "name": "Create snapshot",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com\",\n  \"content\": {}\n}"
            },
            "url": "{{baseUrl}}/api/content/snapshots"
          }
        }
      ]
    },
    {
      "name": "Framework analysis",
      "item": [
        {
          "name": "Golden Circle standalone",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com\",\n  \"stream\": false\n}"
            },
            "url": "{{baseUrl}}/api/analyze/golden-circle-standalone"
          }
        },
        {
          "name": "Brand Archetypes standalone",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com\",\n  \"stream\": false\n}"
            },
            "url": "{{baseUrl}}/api/analyze/brand-archetypes-standalone"
          }
        },
        {
          "name": "B2C Elements standalone",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com\",\n  \"stream\": false\n}"
            },
            "url": "{{baseUrl}}/api/analyze/elements-value-b2c-standalone"
          }
        },
        {
          "name": "List analyses (user-scoped)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/api/analysis"
          }
        }
      ]
    }
  ]
}
