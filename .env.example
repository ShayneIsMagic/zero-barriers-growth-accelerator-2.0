# ============================================
# Zero Barriers Growth Accelerator - Environment
# ============================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# Database (Required)
DATABASE_URL=postgresql://user:password@localhost:5432/zerobarriers

# Authentication (Required)
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Super admin (run: npm run admin:ensure)
SUPER_ADMIN_EMAIL=you@example.com
SUPER_ADMIN_PASSWORD=change-me-to-a-strong-password
SUPER_ADMIN_NAME=Super Admin

# Security
# Auth is OPEN by default (no login) until you set ENABLE_AUTH=true
# DISABLE_AUTH=false also re-enables login without ENABLE_AUTH
# ENABLE_AUTH=true

# Require JWT for /api/analyze, /api/scrape, /api/content, etc. (when auth enabled)
REQUIRE_API_AUTH=false

# Allow open self-service registration
# Defaults: false in production, true in local development
ALLOW_PUBLIC_SIGNUP=true

# NEVER set TEST_MODE=true in production — enables debug routes
TEST_MODE=false

# AI Services (Required — at least GEMINI_API_KEY)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# AI Fallback (Optional — Claude/Anthropic used when Ollama is unavailable)
CLAUDE_API_KEY=your-claude-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-3-haiku-20240307
OPENAI_API_KEY=your-openai-api-key-here
AI_ALLOW_FALLBACKS=false

# Ollama Endpoints
# Local dev default is http://127.0.0.1:11434 via OLLAMA_BASE_URL.
# For Vercel or remote access, set OLLAMA_PUBLIC_URL to a reachable HTTPS endpoint.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_PUBLIC_URL=
OLLAMA_MODEL=llama3.1:8b
OLLAMA_KEEP_ALIVE=6h
OLLAMA_NUM_PREDICT=1400

# Environment
NODE_ENV=development

# Puppeteer content collection (homepage-first by default — matches live content-comparison)
# CONTENT_COLLECTION_MAX_PAGES=0
# CONTENT_COLLECTION_MAX_DEPTH=0
# CONTENT_COLLECTION_TIMEOUT_MS=15000
# Quote paths that contain spaces (unquoted values break at the first space):
# PUPPETEER_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"

# Optional: restrict CORS (comma-separated origins)
# CORS_ORIGIN=http://localhost:3000
